# Base64-encoded Firebase Admin service account JSON. Example:
# FIREBASE_SERVICE_ACCOUNT=eyAie...base64..."
# To create: base64 -w 0 serviceAccountKey.json

FIREBASE_SERVICE_ACCOUNT=

# Note: This must be the BASE64-ENCODED content of the service account JSON from Firebase Console.
# Keep this value secret and do NOT commit your real service account to source control.

# Admin bootstrap secret - used to create the first admin (one-time use)
# Generate a secure random string for production
ADMIN_BOOTSTRAP_SECRET=your-secure-random-bootstrap-secret-change-this-in-production

# ML Flask API URL (used by the Profile page for skill predictions)
VITE_ML_API_URL=https://your-flask-api.onrender.com

# Server API URL (for client-side admin API calls)
VITE_API_URL=http://localhost:3001

# IMPORTANT for mobile/port-forwarding testing:
# Set this to your LAN IP + Vite port so the phone can reach the server.
# Vite proxies /socket.io, /ml, /notify, /admin to localhost:3001 automatically.
# Example: VITE_SERVER_URL=http://192.168.0.104:5173
# For production deployment, set this to your deployed server URL.
VITE_SERVER_URL=http://192.168.0.104:5173
