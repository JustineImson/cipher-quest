# =============================================================================
# SERVER-SIDE SECRETS (Node.js / Express — never exposed to the browser)
# =============================================================================

# Base64-encoded Firebase Admin service account JSON.
# To encode: base64 -w 0 serviceAccountKey.json   (Linux/macOS)
#            [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))  (PowerShell)
FIREBASE_SERVICE_ACCOUNT=

# Admin bootstrap secret — used once to promote the first admin account.
# Generate with: openssl rand -hex 32
ADMIN_BOOTSTRAP_SECRET=

# SMTP credentials for email notifications
EMAIL_USER=
EMAIL_PASS=

# =============================================================================
# PRODUCTION (AWS ECS / Docker)
# =============================================================================

# The public URL of your ECS service (ALB DNS name or custom domain).
# Used for CORS — the Express server will only accept requests from this origin.
# Example: https://cipherquest.example.com
CLIENT_ORIGIN=https://your-domain.com

# Internal URL for the Python ML API container (service name in docker-compose
# or ECS service discovery name). Leave as-is when using docker-compose.
ML_API_URL=http://python-api:5000

# VITE_ variables are baked into the frontend bundle at `npm run build`.
# In production the frontend is served by the same Express server, so
# VITE_SERVER_URL should be the same as your public domain (no port needed).
# Leave blank to use window.location.origin (recommended for same-origin deploys).
VITE_SERVER_URL=

# Firebase client VAPID key for Web Push / FCM
VITE_FIREBASE_VAPID_KEY=

# Google Gemini API key (used client-side for AI puzzle generation)
VITE_GEMINI_API_KEY=

# =============================================================================
# LOCAL DEVELOPMENT ONLY
# =============================================================================

# Uncomment and set your LAN IP when testing on a phone via port forwarding.
# Vite proxies /socket.io, /ml, /notify, /admin → localhost:3001 automatically.
# VITE_SERVER_URL=http://192.168.0.104:5173
